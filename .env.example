# Synthesis Hackathon - Blockchain Skills Agent
# Copy to .env and fill in values. NEVER commit .env.

# ══════════════════════════════════════════════
#  SINGLE NETWORK TOGGLE  ←  change this one line
# ══════════════════════════════════════════════
NETWORK=testnet          # "testnet" | "mainnet"

# ── Hackathon identity ──────────────────────────────────────────────────────
HACKATHON_API_KEY=
ERC8004_ADDRESS=

# ── Testnet  (Base Sepolia, chain 84532) ────────────────────────────────────
# Get a free wallet: python -c "from web3 import Web3; a=Web3().eth.account.create(); print(a.address, a.key.hex())"
# Fund via: https://www.alchemy.com/faucets/base-sepolia
TESTNET_WALLET_KEY=
TESTNET_RPC_URL=https://sepolia.base.org
TESTNET_PROVIDER=uniswap
TESTNET_MAX_TX_VALUE_USD=5

# ── Mainnet  (Base, chain 8453) ─────────────────────────────────────────────
MAINNET_WALLET_KEY=
MAINNET_RPC_URL=https://mainnet.base.org
MAINNET_PROVIDER=uniswap          # or "bankr"
MAINNET_MAX_TX_VALUE_USD=20

# ── Shared API keys ─────────────────────────────────────────────────────────
BANKR_API_KEY=
UNISWAP_API_KEY=

# ── LLM (OpenAI-compatible) ──────────────────────────────────────────────────
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
